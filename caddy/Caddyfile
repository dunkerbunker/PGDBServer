# Listen on port 80 (HTTP)
:80 {
    # Provide basic authentication using environment variables
    # Format: caddy hash-password --plaintext "password"
    basicauth / {
        {$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
    }

    # Proxy reverse traffic to the internal Grafana container on port 3000
    reverse_proxy grafana:3000
}
