# ------------------------------------------------------------------------------
# INFRASTRUCTURE SETTINGS
# ------------------------------------------------------------------------------

# Your Droplet's Private VPC IP (e.g. 10.116.0.2). Run `ip a` on your VPS to find it.
# This ensures Redis and Postgres ONLY communicate on the private network.
VPC_IP=10.0.0.2

# The Public IP of your Droplet (used to access Grafana via HTTP)
PUBLIC_IP=203.0.113.1

# ------------------------------------------------------------------------------
# POSTGRESQL SETTINGS
# ------------------------------------------------------------------------------

# Superuser credentials
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_SUPER_SECRET_PG_PASSWORD

# Project-Specific Credentials (used in the init scripts)
# Make these strong for production!
MALE_LAND_SURVEY_PROD_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD
MALE_LAND_SURVEY_STAGING_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD

# ------------------------------------------------------------------------------
# REDIS SETTINGS
# ------------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_SUPER_SECRET_REDIS_PASSWORD

# ------------------------------------------------------------------------------
# DASHBOARD CREDENTIALS
# ------------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# HTTP Basic Auth credentials for Caddy (Generate with `caddy hash-password`)
# Example: caddy hash-password --plaintext "my_secret_password"
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=CHANGE_ME_CADDY_HASHED_PASSWORD

# ------------------------------------------------------------------------------
# BACKUP SETTINGS (For AWS S3 or DigitalOcean Spaces)
# ------------------------------------------------------------------------------
S3_ENDPOINT=nyc3.digitaloceanspaces.com
S3_BUCKET=my-db-backups
S3_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_SECRET_KEY
